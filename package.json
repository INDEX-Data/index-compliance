{
  "name": "msgraph-compliance-mcp",
  "version": "1.0.0",
  "description": "MCP server for Microsoft 365 compliance assessment — INDEX DSaaS platform",
  "main": "dist/index.js",
  "type": "module",
  "bin": {
    "msgraph-compliance-mcp": "./dist/index.js",
    "msgraph-compliance-setup": "./dist/setup.js"
  },
  "files": [
    "dist/**",
    "README.md"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "start:api": "node dist/api-server.js",
    "setup": "node dist/setup.js",
    "dev:watch": "tsc --watch",
    "dev": "concurrently -n API,WEB -c cyan,magenta \"node dist/api-server.js\" \"npm --prefix web run dev\"",
    "prepublishOnly": "npm run build",
    "pack": "npm pack",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "format": "prettier --write src",
    "format:check": "prettier --check src",
    "typecheck": "tsc --noEmit",
    "prepare": "husky"
  },
  "keywords": [
    "mcp",
    "compliance",
    "microsoft-graph",
    "cmmc",
    "azure",
    "m365"
  ],
  "dependencies": {
    "@anthropic-ai/sdk": "^0.78.0",
    "@clerk/backend": "^3.2.0",
    "@microsoft/microsoft-graph-client": "^3.0.0",
    "@modelcontextprotocol/sdk": "^1.12.0",
    "@neondatabase/serverless": "^1.0.2",
    "@types/multer": "^2.1.0",
    "docx": "^9.6.0",
    "dotenv": "^17.3.1",
    "drizzle-orm": "^0.45.1",
    "express": "^4.18.0",
    "jszip": "^3.10.1",
    "multer": "^2.1.1",
    "resend": "^6.9.3",
    "svix": "^1.88.0",
    "zod": "^3.22.0"
  },
  "lint-staged": {
    "src/**/*.ts": [
      "eslint --fix",
      "prettier --write"
    ],
    "web/app/**/*.{ts,tsx}": [
      "prettier --write"
    ],
    "web/lib/**/*.{ts,tsx}": [
      "prettier --write"
    ],
    "*.{json,md}": [
      "prettier --write"
    ]
  },
  "devDependencies": {
    "@types/express": "^4.17.0",
    "@types/node": "^20.0.0",
    "@typescript-eslint/eslint-plugin": "^8.59.0",
    "@typescript-eslint/parser": "^8.59.0",
    "concurrently": "^9.2.1",
    "drizzle-kit": "^0.31.9",
    "eslint": "^10.2.1",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.3",
    "tsx": "^4.21.0",
    "typescript": "^5.3.0"
  }
}
