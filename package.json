{
  "name": "msgraph-compliance-mcp",
  "version": "1.0.0",
  "description": "MCP server for Microsoft 365 compliance assessment — INDEX DSaaS platform",
  "main": "dist/index.js",
  "type": "module",
  "bin": {
    "msgraph-compliance-mcp": "./dist/index.js",
    "msgraph-compliance-setup": "./dist/setup.js"
  },
  "files": [
    "dist/**",
    "README.md"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "start:api": "node dist/api-server.js",
    "setup": "node dist/setup.js",
    "dev:watch": "tsc --watch",
    "dev": "concurrently -n API,WEB -c cyan,magenta \"node dist/api-server.js\" \"npm --prefix web run dev\"",
    "prepublishOnly": "npm run build",
    "pack": "npm pack"
  },
  "keywords": [
    "mcp",
    "compliance",
    "microsoft-graph",
    "cmmc",
    "azure",
    "m365"
  ],
  "dependencies": {
    "@anthropic-ai/sdk": "^0.78.0",
    "@clerk/backend": "^3.2.0",
    "@microsoft/microsoft-graph-client": "^3.0.0",
    "@modelcontextprotocol/sdk": "^1.12.0",
    "@neondatabase/serverless": "^1.0.2",
    "docx": "^9.6.0",
    "dotenv": "^17.3.1",
    "drizzle-orm": "^0.45.1",
    "express": "^4.18.0",
    "resend": "^6.9.3",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.0",
    "@types/node": "^20.0.0",
    "concurrently": "^9.2.1",
    "drizzle-kit": "^0.31.9",
    "tsx": "^4.21.0",
    "typescript": "^5.3.0"
  }
}
