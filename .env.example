# ============================================================
# INDEX Compliance Platform — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to git — it is in .gitignore.
# ============================================================

# ── Database (Neon PostgreSQL) ──────────────────────────────
# Get from: https://neon.tech → your project → Connection string
DATABASE_URL=postgresql://user:password@host.neon.tech/neondb?sslmode=require

# ── Clerk Authentication ─────────────────────────────────────
# Get from: https://clerk.com → your app → API Keys
CLERK_SECRET_KEY=sk_live_xxxxxxxxxxxxxxxxxxxx
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_live_xxxxxxxxxxxxxxxxxxxx

# Clerk redirect URLs (keep these as-is unless you change routes)
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/

# ── Anthropic AI (for report generation) ────────────────────
# Get from: https://console.anthropic.com → API Keys
ANTHROPIC_API_KEY=sk-proj-xxxxxxxxxxxxxxxxxxxx

# ── API Server ───────────────────────────────────────────────
PORT=3001

# Comma-separated list of allowed frontend origins (no trailing slash)
# Development: http://localhost:3000
# Production:  https://your-app.vercel.app
ALLOWED_ORIGINS=http://localhost:3000

# ── Next.js → API Proxy ──────────────────────────────────────
# Development: leave blank (defaults to http://localhost:3001)
# Production (Vercel): set to your Railway API URL
# INTERNAL_API_URL=https://your-api.railway.app

# ── Azure / Microsoft Graph (per-client, stored in DB) ───────
# These are NOT needed here — users enter their own Azure credentials
# through the INDEX setup wizard. They are stored securely in the DB.
